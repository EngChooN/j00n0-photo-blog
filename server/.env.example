PORT=3001

# --- Database -----------------------------------------------------------
# LOCAL DEV: point at a local Postgres only. Never use prod credentials here.
#   createdb photo_blog_dev
DATABASE_URL="postgresql://localhost:5432/photo_blog_dev"
DIRECT_URL="postgresql://localhost:5432/photo_blog_dev"
#
# PROD (Render): managed by Render's env vars dashboard, not this file.
#   DATABASE_URL=postgresql://postgres.<ref>:<pw>@aws-x.pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgresql://postgres.<ref>:<pw>@aws-x.pooler.supabase.com:5432/postgres

# --- Storage ------------------------------------------------------------
# LOCAL DEV: write photos to ./uploads on disk. Served at /uploads/*.
# PUBLIC_API_BASE_URL must be the origin only (no /api suffix) — /uploads is
# mounted outside the api global prefix.
STORAGE_DRIVER=local
PUBLIC_API_BASE_URL=http://localhost:3001
#
# PROD: STORAGE_DRIVER=supabase plus the three SUPABASE_* vars below.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
# SUPABASE_STORAGE_BUCKET=photos

# --- Auth ---------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=30d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
CLIENT_ORIGIN=http://localhost:3000

# Salt for hashing visitor IPs (comments rate-limit, likes dedup). Random hex.
VISITOR_IP_SALT=replace-with-a-random-hex-string
