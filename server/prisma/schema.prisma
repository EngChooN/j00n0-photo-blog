generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id        String       @id @default(cuid())
  title     String
  caption   String       @default("")
  location  String       @default("")
  takenAt   String       @default("")
  createdAt DateTime     @default(now())
  likeCount Int          @default(0)
  photos    Photo[]
  comments  Comment[]
  likes     LikeRecord[]

  @@index([createdAt])
}

model Comment {
  id            String   @id @default(cuid())
  postId        String
  name          String
  body          String
  visitorIpHash String
  createdAt     DateTime @default(now())
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([visitorIpHash, createdAt])
}

model LikeRecord {
  postId        String
  visitorIpHash String
  createdAt     DateTime @default(now())
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, visitorIpHash])
}

model Photo {
  id        String   @id @default(cuid())
  postId    String
  src       String
  width     Int
  height    Int
  position  Int
  exif      Json?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, position])
}

model GuestbookEntry {
  id        String   @id @default(cuid())
  name      String
  message   String
  createdAt DateTime @default(now())
}
