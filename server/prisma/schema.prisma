generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id        String       @id @default(cuid())
  title     String
  caption   String       @default("")
  location  String       @default("")
  takenAt   String       @default("")
  createdAt DateTime     @default(now())
  likeCount Int          @default(0)
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  photos    Photo[]
  comments  Comment[]
  likes     LikeRecord[]

  @@index([createdAt])
  @@index([projectId])
}

enum ProjectStatus {
  ongoing
  completed
}

model Project {
  id            String        @id @default(cuid())
  title         String
  concept       String?
  coverPhotoUrl String?
  startDate     String?
  endDate       String?
  status        ProjectStatus @default(ongoing)
  isPublic      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  posts         Post[]

  @@index([isPublic, status, updatedAt(sort: Desc)])
}

model Comment {
  id            String   @id @default(cuid())
  postId        String
  name          String
  body          String
  visitorIpHash String
  createdAt     DateTime @default(now())
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([visitorIpHash, createdAt])
}

model LikeRecord {
  postId        String
  visitorIpHash String
  createdAt     DateTime @default(now())
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, visitorIpHash])
}

model Photo {
  id        String   @id @default(cuid())
  postId    String
  src       String
  width     Int
  height    Int
  position  Int
  exif      Json?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, position])
}

model GuestbookEntry {
  id        String   @id @default(cuid())
  name      String
  message   String
  createdAt DateTime @default(now())
}
